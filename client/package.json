{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --external:./vite.js --external:vite --external:@google-cloud/storage --packages=external --bundle --format=esm --outdir=dist && esbuild server/meeting-agenda-pdf-generator.ts --platform=node --external:date-fns --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "type-check": "tsc",
    "check:routes": "node scripts/check-legacy-routes.js",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx server/run-migrations.ts",
    "db:migrate-focus": "tsx scripts/migrate-focus-areas.ts",
    "db:seed": "tsx scripts/seed-dev-database.ts",
    "db:reset": "tsx scripts/reset-dev-database.ts",
    "verify:migrations": "tsx scripts/verify-migrations.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "jest --config jest.config.js",
    "test:client": "jest --config jest.config.client.js",
    "test:server": "jest --config jest.config.js",
    "test:integration": "jest --config tests/integration/jest.config.cjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --config jest.config.js && jest --coverage --config jest.config.client.js",
    "test:coverage:client": "jest --coverage --config jest.config.client.js",
    "test:coverage:server": "jest --coverage --config jest.config.js",
    "test:ci": "npm run test:unit && npm run test:integration"
  },
